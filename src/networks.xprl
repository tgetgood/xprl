(def μ
  (ν senv in ccs
     ;; N.B.: will let be applicative, or should I have a simpler let*?
     ;; Destructuring is non-negotiable.
     ~(let [[params body] (<! ~in)]
        ~(>! ~(get ~ccs :return)
            ~(ν denv in ccs
                ~(let [dynext (bind ~params (<! ~in))]
                   ~(apply body (merge senv ))))))))

(def wrap
  (μ f
     ~(μ args
         ~(f . ~~args))))
